# Dependencies — reinstalled inside the container
node_modules

# Build output — rebuilt inside the container
build

# Environment files — injected via build args / secrets, never baked in
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# VCS
.git
.gitignore

# Editor & OS artifacts
.vscode
.idea
*.DS_Store
Thumbs.db

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test output
coverage

# CI/CD configs (not needed in the image)
.github

# Docker files themselves (avoid recursive copy)
Dockerfile
docker-compose.yml
.dockerignore
